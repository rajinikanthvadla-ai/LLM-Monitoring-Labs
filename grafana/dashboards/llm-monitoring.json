{
  "title": "LLM Monitoring Lab",
  "uid": "llm-monitoring-lab",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(llm_requests_total)",
          "legendFormat": "Total"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "id": 2,
      "title": "Error Rate %",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "100 * sum(rate(llm_requests_total{status='error'}[5m])) / sum(rate(llm_requests_total[5m]))",
          "legendFormat": "Error %"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 10 }] } } }
    },
    {
      "id": 3,
      "title": "Avg Latency (p50)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by(le) (rate(llm_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 15 }] } } }
    },
    {
      "id": 4,
      "title": "Total Tokens Used",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(llm_tokens_total)",
          "legendFormat": "Tokens"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "purple", "value": null }] } } }
    },
    {
      "id": 5,
      "title": "Active Sessions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "llm_active_sessions",
          "legendFormat": "Sessions"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "id": 6,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "sum by(app) (rate(llm_requests_total[1m]))", "legendFormat": "{{app}}" },
        { "expr": "sum(rate(llm_requests_total{status='error'}[1m]))", "legendFormat": "errors" }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 7,
      "title": "Latency Percentiles",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by(le)(rate(llm_request_duration_seconds_bucket[2m])))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by(le)(rate(llm_request_duration_seconds_bucket[2m])))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by(le)(rate(llm_request_duration_seconds_bucket[2m])))", "legendFormat": "p99" }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 8,
      "title": "Token Usage Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "expr": "sum by(token_type)(rate(llm_tokens_total[1m]))", "legendFormat": "{{token_type}} tokens/s" }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "id": 9,
      "title": "Latency by Model",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by(le, model)(rate(llm_request_duration_seconds_bucket[2m])))", "legendFormat": "{{model}} p95" }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 10,
      "title": "Errors by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        { "expr": "sum by(error_type)(rate(llm_errors_total[1m]))", "legendFormat": "{{error_type}}" }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 11,
      "title": "Tokens per Request (avg)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        { "expr": "sum by(model)(rate(llm_tokens_total[2m])) / sum by(model)(rate(llm_requests_total[2m]))", "legendFormat": "{{model}} avg tokens/req" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 12,
      "title": "RAG — Retrieval Latency vs Generation Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by(le)(rate(llm_rag_retrieval_seconds_bucket[2m])))", "legendFormat": "retrieval p95" },
        { "expr": "histogram_quantile(0.95, sum by(le)(rate(llm_rag_generation_seconds_bucket[2m])))", "legendFormat": "generation p95" }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 13,
      "title": "Retry Attempts",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        { "expr": "sum by(reason)(rate(llm_retries_total[1m]))", "legendFormat": "{{reason}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } }
    }
  ]
}
