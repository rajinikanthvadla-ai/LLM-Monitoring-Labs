# ============================================================
# LLM Monitoring Lab — Environment Variables
# Copy to .env and edit as needed
# ============================================================

# ── Ollama ──────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1

# Models to use (pull after stack is up — see README Quick Start)
DEFAULT_MODEL=llama3.2:1b
FAST_MODEL=llama3.2:1b
SMART_MODEL=mistral:7b

# ── Langfuse (self-hosted) ───────────────────────────────────
# Keys are pre-set in docker-compose.yml — change if you modify them
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-labpublickey1234
LANGFUSE_SECRET_KEY=sk-lf-labsecretkey1234
LANGFUSE_TIMEOUT=120

# ── Phoenix (Arize) ──────────────────────────────────────────
# grpc (default) → port 4317; http → PHOENIX_COLLECTOR_ENDPOINT base URL, /v1/traces appended if missing
PHOENIX_OTLP_PROTOCOL=grpc
PHOENIX_OTLP_GRPC_ENDPOINT=http://localhost:4317
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006
PHOENIX_OTLP_TIMEOUT_SEC=120
OTEL_BSP_EXPORT_TIMEOUT_MS=120000

# ── Prometheus Pushgateway ───────────────────────────────────
# Used by batch/script apps to push one-off metrics
PROMETHEUS_PUSHGATEWAY=localhost:9091

# ── Metrics Server ───────────────────────────────────────────
METRICS_PORT=8000
